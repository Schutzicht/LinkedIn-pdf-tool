# Google Gemini API Key (verplicht)
GEMINI_API_KEY=

# AI model (optioneel, default: gemini-2.0-flash)
AI_MODEL=gemini-2.0-flash

# Server poort (optioneel, default: 3000)
PORT=3000

# Omgeving (optioneel, default: development)
NODE_ENV=development

# Log level (optioneel, default: info in production, debug in development)
LOG_LEVEL=

# Puppeteer: pad naar Chrome executable (optioneel, nodig bij Docker)
PUPPETEER_EXECUTABLE_PATH=
